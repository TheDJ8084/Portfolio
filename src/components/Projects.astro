---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

let projects = await getCollection('projects');

// Sort by date descending
projects.sort((a, b) => {
  const dateA = a.data.startDate ? new Date(a.data.startDate).getTime() : 0;
  const dateB = b.data.startDate ? new Date(b.data.startDate).getTime() : 0;
  return dateB - dateA;
});

// Helper for formatting dates
function formatDate(date: any) {
  if (!date) return '';
  return new Date(date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<section id="projects" class="projects-section">
  <div class="projects-header">
    <h2 class="section-title">Selected Work</h2>
    <span class="projects-count">({projects.length})</span>
  </div>

  <div class="projects-grid">
    {projects.map((project) => (
      <a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/projects/${project.id}`} class="project-card">
        <div class="card-image-wrapper">
          {project.data.image ? (
            <Image src={project.data.image} alt={project.data.title} width={800} class="card-image" />
          ) : (
            <div class="visual-placeholder"></div>
          )}
        </div>
        <div class="card-content">
          <div class="card-meta">
            <span class="card-category">{project.data.tags?.[0] || 'Project'}</span>
            {project.data.startDate && (
              <span class="card-date">
                {formatDate(project.data.startDate)} {project.data.endDate ? `- ${formatDate(project.data.endDate)}` : ''}
              </span>
            )}
          </div>
          <h3 class="card-title">{project.data.title}</h3>
          {project.data.description && (
            <p class="card-description">{project.data.description}</p>
          )}
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .projects-section {
    padding: 10vh 5vw;
    background-color: var(--bg-color);
    position: relative;
    z-index: 10;
  }

  .projects-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 5vh;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 4rem);
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .projects-count {
    font-family: var(--font-mono);
    color: var(--text-muted);
    font-size: 1.2rem;
  }

  /* Grid Layout */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 3rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-decoration: none;
    color: var(--text-color);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--border-radius);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    transition: background 0.4s ease;
  }

  .project-card:hover .card-image-wrapper {
    background: rgba(255, 255, 255, 0.04);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: contain; /* Zero cropping */
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.6s ease;
    filter: brightness(0.8) grayscale(20%);
    border-radius: 4px;
  }

  .visual-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, #18181b, #27272a);
    border-radius: 4px;
  }

  .project-card:hover .card-image {
    transform: scale(1.03);
    filter: brightness(1) grayscale(0%);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .card-category {
    color: var(--accent-primary);
  }

  .card-title {
    font-size: 1.8rem;
    font-weight: 800;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.1;
    transition: color 0.3s ease;
  }

  .project-card:hover .card-title {
    color: var(--accent-primary);
  }

  .card-description {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
