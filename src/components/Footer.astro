---
const currentYear = new Date().getFullYear();
---
<footer id="contact" class="footer">
  <div class="container">
    <div class="footer-content glass-panel">
      <div class="info">
        <h2>Let's build something <span class="text-gradient">amazing</span> together.</h2>
        <p>Currently available for freelance opportunities.</p>
        <a href="mailto:hello@example.com" class="email-link hover-lift">hello@example.com</a>
      </div>
      <div class="socials">
        <a href="https://github.com/TheDJ8084" target="_blank" rel="noopener noreferrer" class="social-link hover-lift">GitHub</a>
        <a href="#" target="_blank" rel="noopener noreferrer" class="social-link hover-lift">LinkedIn</a>
        <a href="#" target="_blank" rel="noopener noreferrer" class="social-link hover-lift">Twitter</a>
      </div>
    </div>
    <div class="bottom-bar">
      <p>&copy; {currentYear} Luka Ramp. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 4rem 2rem 2rem;
    position: relative;
    z-index: 10;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-content {
    padding: 4rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .info {
    flex: 1;
    min-width: 300px;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
    max-width: 500px;
  }

  p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .email-link {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-color);
    border-bottom: 2px solid var(--accent-primary);
    padding-bottom: 0.2rem;
    display: inline-block;
  }

  .email-link:hover {
    color: var(--accent-primary);
  }

  .socials {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .social-link {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: var(--transition-smooth);
  }

  .social-link:hover {
    color: var(--accent-secondary);
    transform: translateX(5px);
  }

  .bottom-bar {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid var(--glass-border);
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .footer-content {
      padding: 2rem;
      flex-direction: column;
      text-align: center;
    }
    
    .socials {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
    }

    .social-link:hover {
      transform: translateY(-5px);
    }
  }
</style>
