---
import { Image } from 'astro:assets';
import { getEntry, render } from 'astro:content';

const aboutEntry = await getEntry('about', 'about');
const about = aboutEntry?.data || {
  headline: 'Loading...',
  image: null
};
const { Content } = aboutEntry ? await render(aboutEntry) : { Content: () => null };
---

<section id="about" class="about-section">
  <div class="container glass-panel">
    <div class="about-grid">
      <div class="image-wrapper animate-fade-in delay-100">
        {about.image ? (
          <Image src={about.image} alt="Profile Image" />
        ) : (
          <div class="image-placeholder">
            <span>Upload Image in CMS</span>
          </div>
        )}
      </div>
      <div class="content animate-fade-in delay-200">
        <h2 class="section-title">About <span class="text-gradient">Me</span></h2>
        <h3>{about.headline}</h3>
        <Content />
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 8rem 2rem;
    position: relative;
    z-index: 10;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: center;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }

  .image-wrapper {
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid rgba(255, 255, 255, 0.1);
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
    font-size: 0.9rem;
    text-align: center;
    padding: 2rem;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.5rem;
  }

  h3 {
    font-size: 1.5rem;
    color: var(--text-color);
    font-weight: 500;
  }

  p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-muted);
  }
</style>
