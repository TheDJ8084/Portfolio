---
import { Image } from 'astro:assets';
import { getEntry, render } from 'astro:content';

const aboutEntry = await getEntry('about', 'about');
const about = aboutEntry?.data || {
  headline: 'Loading...',
  image: null
};
const { Content } = aboutEntry ? await render(aboutEntry) : { Content: () => null };
---

<section id="about" class="about-section">
  <div class="container">
    <div class="about-header">
      <h2 class="massive-title">ABOUT</h2>
    </div>
    
    <div class="about-grid">
      <div class="image-column animate-fade-in delay-100">
        <div class="image-wrapper">
          {about.image ? (
            <Image src={about.image} alt="Profile Image" class="profile-image" />
          ) : (
            <div class="image-placeholder">
              <span>[Upload Image in CMS]</span>
            </div>
          )}
        </div>
      </div>
      
      <div class="content-column animate-fade-in delay-200">
        <h3 class="headline">{about.headline}</h3>
        <div class="editorial-text">
          <Content />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 15vh 5vw;
    background-color: var(--bg-color);
    position: relative;
    z-index: 10;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .about-header {
    margin-bottom: 5vh;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .massive-title {
    font-size: clamp(2rem, 5vw, 4rem);
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 6rem;
    align-items: start;
  }

  .image-column {
    position: sticky;
    top: 15vh;
  }

  .image-wrapper {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: var(--border-radius);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
  }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%) contrast(1.1);
    transition: filter 0.6s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .image-wrapper:hover .profile-image {
    filter: grayscale(0%) contrast(1);
    transform: scale(1.03);
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(45deg, #18181b, #27272a);
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.9rem;
  }

  .content-column {
    padding-top: 2rem;
  }

  .headline {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text-color);
    line-height: 1.1;
    margin-bottom: 3rem;
    text-transform: uppercase;
  }

  .editorial-text {
    font-size: 1.25rem;
    line-height: 1.8;
    color: var(--text-muted);
    max-width: 700px;
  }

  .editorial-text :global(p) {
    margin-bottom: 2rem;
  }

  .editorial-text :global(strong) {
    color: var(--text-color);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .image-column {
      position: relative;
      top: 0;
      max-width: 500px;
    }
  }
</style>
