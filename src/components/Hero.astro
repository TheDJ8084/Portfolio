<section class="hero">
  <div class="hero-content">
    <div class="kinetic-line">
      <h1 class="kinetic-text" data-speed="-1">LUKA</h1>
    </div>
    <div class="kinetic-line">
      <h1 class="kinetic-text outline" data-speed="1">RAMP</h1>
    </div>
    <div class="hero-footer">
      <p class="subtitle fade-up">Lighting, Audio, and Video Engineer</p>
      <p class="subtitle right fade-up">Based in the Netherlands</p>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    padding: 0;
    overflow: hidden;
  }

  .hero-content {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .kinetic-line {
    width: 100vw;
    display: flex;
    white-space: nowrap;
    overflow: visible;
  }

  .kinetic-text {
    font-size: var(--text-kinetic);
    font-weight: 900;
    line-height: 0.8;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    padding: 0 5vw;
  }

  .kinetic-text.outline {
    color: transparent;
    -webkit-text-stroke: 2px var(--text-muted);
  }

  .hero-footer {
    position: absolute;
    bottom: 10vh;
    left: 5vw;
    right: 5vw;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    color: var(--text-muted);
    max-width: 300px;
  }

  .subtitle.right {
    text-align: right;
  }

  @media (max-width: 768px) {
    .hero-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .subtitle.right {
      text-align: left;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Initial load animation
  gsap.from('.kinetic-line', {
    y: 100,
    opacity: 0,
    duration: 1.5,
    stagger: 0.2,
    ease: 'power4.out',
  });

  gsap.from('.fade-up', {
    y: 30,
    opacity: 0,
    duration: 1,
    stagger: 0.2,
    ease: 'power3.out',
    delay: 0.5
  });

  // Kinetic scroll physics
  const kineticTexts = document.querySelectorAll('.kinetic-text');
  
  kineticTexts.forEach((text) => {
    const speed = text.getAttribute('data-speed') || 1;
    gsap.to(text, {
      x: () => `${50 * Number(speed)}vw`,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1, // Smooth scrubbing
      }
    });
  });
</script>
