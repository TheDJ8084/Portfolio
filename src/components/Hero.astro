---
---
<section class="hero">
  <div class="hero-content">
    <h1 class="animate-fade-in">
      Hi, I'm <span class="text-gradient">Luka Ramp</span>
    </h1>
    <p class="subtitle animate-fade-in delay-100">
      Professional Lighting, Audio, and Video Engineer bringing events to life.
    </p>
    <div class="actions animate-fade-in delay-200">
      <a href="#projects" class="btn btn-primary hover-lift">View My Work</a>
      <a href="#contact" class="btn btn-secondary hover-lift">Get In Touch</a>
    </div>
  </div>
  <div class="hero-bg animate-fade-in delay-300">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 0 2rem;
    overflow: hidden;
  }

  .hero-content {
    text-align: center;
    z-index: 10;
    max-width: 800px;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .subtitle {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--text-muted);
    margin-bottom: 3rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .btn {
    padding: 1rem 2rem;
    border-radius: 99px;
    font-weight: 600;
    font-size: 1.1rem;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .btn-primary {
    background: var(--accent-gradient);
    color: #fff;
    border: none;
  }

  .btn-secondary {
    background: var(--glass-bg);
    color: var(--text-color);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(10px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Abstract background glowing orbs */
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
    animation: float 20s infinite alternate ease-in-out;
  }

  .glow-1 {
    background: var(--accent-primary);
    top: -10%;
    right: -10%;
  }

  .glow-2 {
    background: var(--accent-secondary);
    bottom: -10%;
    left: -10%;
    animation-delay: -10s;
  }

  @keyframes float {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-100px, 50px) scale(1.2); }
  }

  @media (max-width: 600px) {
    .actions {
      flex-direction: column;
    }
  }
</style>
